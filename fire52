<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Dashboard FIRE – Plano Tiago</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Fonte Google -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
  <!-- Chart.js para gráficos -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root {
      --bg: #0b1020;
      --bg-elevated: #151a2c;
      --accent: #4ade80;
      --accent-soft: rgba(74, 222, 128, 0.18);
      --text: #f9fafb;
      --muted: #9ca3af;
      --danger: #f97373;
      --border: #1f2937;
      --card-radius: 14px;
      --shadow-soft: 0 18px 40px rgba(0, 0, 0, 0.45);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      background: radial-gradient(circle at top, #111827 0, #020617 55%, #000 100%);
      color: var(--text);
      min-height: 100vh;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 20;
      backdrop-filter: blur(16px);
      background: linear-gradient(to bottom, rgba(2, 6, 23, 0.95), rgba(2, 6, 23, 0.7));
      border-bottom: 1px solid rgba(148, 163, 184, 0.2);
    }

    .nav {
      max-width: 1100px;
      margin: 0 auto;
      padding: 12px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .logo-pill {
      width: 34px;
      height: 34px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 20%, #4ade80, #22c55e);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 0.9rem;
      color: #022c22;
    }

    .nav-title {
      display: flex;
      flex-direction: column;
    }

    .nav-title span:first-child {
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
    }

    .nav-title span:last-child {
      font-size: 1.05rem;
      font-weight: 600;
    }

    .nav-right {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .tag {
      font-size: 0.78rem;
      padding: 4px 10px;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      color: var(--muted);
    }

    .tag span {
      color: var(--accent);
      font-weight: 600;
    }

    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 18px 20px 40px 20px;
    }

    .grid {
      display: grid;
      gap: 18px;
    }

    @media (min-width: 900px) {
      .grid-2 {
        grid-template-columns: 2fr 1.5fr;
      }
      .grid-3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    .card {
      background: radial-gradient(circle at top left, #111827, #020617 55%);
      border-radius: var(--card-radius);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-soft);
      padding: 16px 18px;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top right, rgba(74, 222, 128, 0.08), transparent 60%);
      opacity: 0.9;
      pointer-events: none;
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }

    .card-title {
      font-size: 0.96rem;
      font-weight: 600;
    }

    .card-subtitle {
      font-size: 0.78rem;
      color: var(--muted);
    }

    .pill {
      font-size: 0.72rem;
      padding: 3px 9px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.8);
      border: 1px solid rgba(148, 163, 184, 0.4);
      color: var(--muted);
    }

    .kpi-main {
      font-size: 1.7rem;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .kpi-label {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .kpi-row {
      display: flex;
      gap: 10px;
      margin-top: 8px;
      flex-wrap: wrap;
    }

    .kpi-chip {
      font-size: 0.78rem;
      padding: 4px 8px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.9);
      border: 1px solid rgba(148, 163, 184, 0.35);
      color: var(--muted);
    }

    .kpi-chip strong {
      color: var(--accent);
    }

    .kpi-chip.bad strong {
      color: var(--danger);
    }

    .scenario-card {
      padding: 10px 10px 12px 10px;
      border-radius: 10px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: rgba(15, 23, 42, 0.95);
      margin-top: 6px;
    }

    .scenario-card h4 {
      font-size: 0.86rem;
      margin-bottom: 4px;
    }

    .scenario-card p {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.4;
    }

    .scenario-kpi {
      font-size: 1.1rem;
      font-weight: 600;
      margin: 4px 0;
    }

    .scenario-meta {
      font-size: 0.76rem;
      color: var(--muted);
    }

    .badge-suggested {
      font-size: 0.72rem;
      padding: 2px 6px;
      border-radius: 6px;
      background: var(--accent-soft);
      color: var(--accent);
      margin-left: 6px;
    }

    .timeline {
      font-size: 0.8rem;
      margin-top: 8px;
    }

    .timeline-row {
      display: flex;
      justify-content: space-between;
      padding: 4px 0;
      border-bottom: 1px dashed rgba(55, 65, 81, 0.6);
    }

    .timeline-row:last-child {
      border-bottom: none;
    }

    .timeline-label {
      color: var(--muted);
    }

    .timeline-value {
      font-weight: 500;
    }

    .chip-age {
      font-size: 0.78rem;
      padding: 3px 7px;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.4);
      color: var(--muted);
    }

    .chart-container {
      position: relative;
      height: 230px;
      margin-top: 6px;
    }

    .section-title {
      font-size: 0.86rem;
      font-weight: 600;
      margin-bottom: 4px;
    }

    .section-subtitle {
      font-size: 0.78rem;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .footer-note {
      margin-top: 18px;
      font-size: 0.8rem;
      color: var(--muted);
      border-top: 1px dashed rgba(55, 65, 81, 0.7);
      padding-top: 10px;
    }

    .footer-note strong {
      color: var(--accent);
    }
  </style>
</head>
<body>
<header>
  <div class="nav">
    <div class="nav-left">
      <div class="logo-pill">TF</div>
      <div class="nav-title">
        <span>Plano FIRE</span>
        <span>Dashboard Patrimônio & Liberdade</span>
      </div>
    </div>
    <div class="nav-right">
      <div class="tag">Alvo: <span>FIRE aos 50–52</span></div>
      <div class="tag">Meta herança: <span>R$ 10M aos 90</span></div>
    </div>
  </div>
</header>

<main>
  <!-- Linha superior: visão geral + gráfico patrimônio -->
  <div class="grid grid-2">
    <!-- Card visão geral -->
    <section class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Snapshot do Plano</div>
          <div class="card-subtitle">Situação atual e objetivos de longo prazo</div>
        </div>
        <span class="pill">Atual: 46 anos</span>
      </div>

      <div class="kpi-main">R$ 17.500.000</div>
      <div class="kpi-label">Patrimônio líquido considerado hoje (R$ 4,5M + R$ 13M)</div>

      <div class="kpi-row" style="margin-top: 10px;">
        <div class="kpi-chip">
          Poupança anual até FIRE: <strong>R$ 2.400.000</strong>
        </div>
        <div class="kpi-chip">
          Retorno alvo real: <strong>4% a.a.</strong>
        </div>
        <div class="kpi-chip">
          Doação aos filhos (60 anos): <strong>R$ 2.000.000</strong>
        </div>
      </div>

      <div class="kpi-row">
        <div class="kpi-chip">
          Meta final aos 90: <strong>R$ 10.000.000</strong>
        </div>
        <div class="kpi-chip bad">
          Gasto atual alvo (46 anos): <strong>A definir</strong>
        </div>
      </div>

      <div class="timeline">
        <div class="section-title" style="margin-top: 10px;">Linha do tempo chave</div>
        <div class="timeline-row">
          <div class="timeline-label">Hoje</div>
          <div class="timeline-value">46 anos · Fase de acumulação</div>
        </div>
        <div class="timeline-row">
          <div class="timeline-label">Opção FIRE 1</div>
          <div class="timeline-value">50 anos · ~R$ 108k/mês</div>
        </div>
        <div class="timeline-row">
          <div class="timeline-label">Opção FIRE 2</div>
          <div class="timeline-value">52 anos · ~R$ 136k/mês</div>
        </div>
        <div class="timeline-row">
          <div class="timeline-label">FIRE máximo seguro</div>
          <div class="timeline-value">55 anos · ~R$ 185k/mês</div>
        </div>
        <div class="timeline-row">
          <div class="timeline-label">Legado alvo</div>
          <div class="timeline-value">90 anos · R$ 10M</div>
        </div>
      </div>
    </section>

    <!-- Card gráfico patrimônio -->
    <section class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Curva de Patrimônio</div>
          <div class="card-subtitle">Evolução estimada (cenário FIRE aos 50)</div>
        </div>
        <span class="chip-age">46 → 90 anos</span>
      </div>

      <div class="chart-container">
        <canvas id="wealthChart"></canvas>
      </div>
    </section>
  </div>

  <!-- Linha intermediária: cenários FIRE -->
  <div class="grid grid-3" style="margin-top: 18px;">
    <section class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Cenário 1 · FIRE aos 50</div>
          <div class="card-subtitle">Aposentadoria precoce, liberdade máxima</div>
        </div>
        <span class="pill">Cenário agressivo</span>
      </div>
      <div class="scenario-kpi">R$ 108.300/mês</div>
      <div class="scenario-meta">Gasto real máximo (46 → 90) para chegar com R$ 10M aos 90.</div>
      <div class="scenario-card">
        <h4>Características</h4>
        <p>
          · Fim do trabalho aos 50 anos<br>
          · 40 anos consumindo patrimônio<br>
          · Exige mais disciplina em gastos e gestão de risco<br>
          · Ainda confortável, porém com margem menor para choques negativos.
        </p>
      </div>
    </section>

    <section class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Cenário 2 · FIRE aos 52</div>
          <div class="card-subtitle">Equilíbrio entre tempo e segurança</div>
        </div>
        <span class="pill">Recomendado</span>
      </div>
      <div class="scenario-kpi">
        R$ 136.073/mês
        <span class="badge-suggested">Sweet spot</span>
      </div>
      <div class="scenario-meta">
        Gasto real máximo para terminar aos 90 com R$ 10M.
      </div>
      <div class="scenario-card">
        <h4>Por que é o “sweet spot”?</h4>
        <p>
          · Ainda é aposentadoria precoce<br>
          · Gasto mensal bem acima do padrão atual<br>
          · Margem de segurança confortável<br>
          · Bom balanço entre vida ativa e robustez financeira.
        </p>
      </div>
    </section>

    <section class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Cenário 3 · FIRE aos 55</div>
          <div class="card-subtitle">Máxima robustez</div>
        </div>
        <span class="pill">Ultra conservador</span>
      </div>
      <div class="scenario-kpi">R$ 184.677/mês</div>
      <div class="scenario-meta">
        Gasto máximo possível mantendo R$ 10M aos 90.
      </div>
      <div class="scenario-card">
        <h4>Características</h4>
        <p>
          · Menos anos de FIRE, porém com altíssimo conforto<br>
          · Grande amortecedor contra crises, saúde, família<br>
          · Cenário indicado se a prioridade for 100% segurança.
        </p>
      </div>
    </section>
  </div>

  <!-- Linha inferior: saving vs spending + “happiness” -->
  <div class="grid grid-2" style="margin-top: 18px;">
    <section class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Saving vs Spending</div>
          <div class="card-subtitle">Acumulação até FIRE e consumo planejado depois</div>
        </div>
        <span class="pill">Fluxo anual</span>
      </div>
      <div class="chart-container">
        <canvas id="cashflowChart"></canvas>
      </div>
    </section>

    <section class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Energia x Dinheiro (Happiness)</div>
          <div class="card-subtitle">Aproveitar mais quando a saúde é maior</div>
        </div>
        <span class="pill">Modelo Zerobook</span>
      </div>
      <p class="section-subtitle">
        Ideia: combinar <strong>nível de gastos</strong> com <strong>nível de energia/saúde</strong> ao longo da idade,
        para que o dinheiro seja usado nos anos em que gera mais felicidade marginal.
      </p>
      <div class="chart-container">
        <canvas id="happinessChart"></canvas>
      </div>
    </section>
  </div>

  <div class="footer-note">
    Este dashboard é um modelo conceitual do seu plano FIRE baseado nas premissas atuais
    (patrimônio, poupança, rentabilidade real de 4% a.a., doação aos 60, meta de R$ 10M aos 90).
    Pequenas mudanças em retorno, inflação ou estilo de vida podem exigir ajustes, que seu
    <strong>Agente Assessor de Investimentos</strong> pode recalibrar periodicamente.
  </div>
</main>

<script>
  // ---- Wealth Curve (cenário exemplo FIRE aos 50) ----
  const ctxWealth = document.getElementById('wealthChart').getContext('2d');

  // Idades de 46 a 90 (evolução simplificada, apenas para visual)
  const ages = [];
  for (let a = 46; a <= 90; a++) ages.push(a);

  // Exemplo de curva suavizada só para visual (substituível por dados reais)
  // Aqui: crescimento até ~55, depois queda controlada até ~10M.
  const wealthData = ages.map(age => {
    if (age === 46) return 17.5;
    if (age <= 50) return 17.5 + (age - 46) * 4;      // acumulação forte
    if (age <= 60) return 33 + (60 - age) * 0.7;      // leve queda
    if (age <= 75) return 26 - (age - 60) * 0.7;      // queda gradual
    return 15 - (age - 75) * 0.3;                     // converge para ~10
  });

  new Chart(ctxWealth, {
    type: 'line',
    data: {
      labels: ages,
      datasets: [{
        label: 'Patrimônio estimado (R$ milhões, base real)',
        data: wealthData,
        tension: 0.25,
        borderWidth: 2,
        pointRadius: 0,
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => `R$ ${ctx.parsed.y.toFixed(1)} M`
          }
        }
      },
      scales: {
        x: {
          ticks: { color: '#9ca3af' },
          grid: { color: 'rgba(55,65,81,0.5)' }
        },
        y: {
          ticks: {
            color: '#9ca3af',
            callback: v => `R$ ${v} M`
          },
          grid: { color: 'rgba(55,65,81,0.5)' }
        }
      }
    }
  });

  // ---- Saving vs Spending ----
  const ctxCash = document.getElementById('cashflowChart').getContext('2d');

  const savingsData = ages.map(age => (age < 50 ? 2.4 : 0));
  const spendingData = ages.map(age => (age >= 50 ? 1.3 : 0));

  new Chart(ctxCash, {
    type: 'line',
    data: {
      labels: ages,
      datasets: [
        {
          label: 'Poupança anual (R$ milhões)',
          data: savingsData,
          borderWidth: 2,
          tension: 0.2,
          pointRadius: 0,
        },
        {
          label: 'Gasto anual (R$ milhões, cenário 50)',
          data: spendingData,
          borderWidth: 2,
          tension: 0.2,
          pointRadius: 0,
        }
      ]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { labels: { color: '#e5e7eb', font: { size: 11 } } }
      },
      scales: {
        x: {
          ticks: { color: '#9ca3af' },
          grid: { color: 'rgba(55,65,81,0.5)' }
        },
        y: {
          ticks: {
            color: '#9ca3af',
            callback: v => `R$ ${v.toFixed(1)} M`
          },
          grid: { color: 'rgba(55,65,81,0.5)' }
        }
      }
    }
  });

  // ---- Happiness Curve ----
  const ctxHappy = document.getElementById('happinessChart').getContext('2d');

  // Proxy de saúde (100% aos 46, 20% aos 90)
  const healthCurve = ages.map((_, i) => 100 - (i * (80 / (ages.length - 1))));
  // Proxy de gasto relativo (usando cenário 50 como base)
  const spendCurve = ages.map(age => (age >= 50 ? 1 : 0));

  const happiness = ages.map((_, i) => (healthCurve[i] / 100) * (spendCurve[i]));

  new Chart(ctxHappy, {
    type: 'line',
    data: {
      labels: ages,
      datasets: [{
        label: 'Índice de felicidade financeira (proxy)',
        data: happiness,
        borderWidth: 2,
        tension: 0.25,
        pointRadius: 0,
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false }
      },
      scales: {
        x: {
          ticks: { color: '#9ca3af' },
          grid: { color: 'rgba(55,65,81,0.5)' }
        },
        y: {
          ticks: {
            color: '#9ca3af',
            callback: v => v.toFixed(1)
          },
          grid: { color: 'rgba(55,65,81,0.5)' }
        }
      }
    }
  });
</script>
</body>
</html>